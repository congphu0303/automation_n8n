# ═══════════════════════════════════════════════════════════════════
# MONGODB ATLAS CONNECTION
# ═══════════════════════════════════════════════════════════════════
# Hướng dẫn:
#   1. Vào https://cloud.mongodb.com → Cluster → Connect
#   2. Chọn "Connect your application"
#   3. Copy connection string
#   4. Thay <username> và <password> bằng database user đã tạo
#   5. Thay <cluster-name> bằng tên cluster của bạn
# Ví dụ: mongodb+srv://admin:mysecretpass@cluster0.xxxxx.mongodb.net/approval_system
MONGO_URI=mongodb+srv://n8n:automation123@cluster0.tywp9et.mongodb.net/approval_system?appName=Cluster0
# ═══════════════════════════════════════════════════════════════════
# JWT SECRET KEY
# ═══════════════════════════════════════════════════════════════════
# Tạo key ngẫu nhiên:
#   Terminal: openssl rand -hex 32
# Hoặc truy cập: https://randomkeygen.com → CodeIgniter Encryption Keys
JWT_SECRET=7f551b3f7f0980bb6e23ca3977c68846be0689b0222a0df8b556f8f1176bc5a7


# ═══════════════════════════════════════════════════════════════════
# SMTP EMAIL CONFIG (Gửi email thật)
# ═══════════════════════════════════════════════════════════════════
# Hướng dẫn lấy SMTP_USER & SMTP_PASS:
#   1. Đăng nhập Gmail
#   2. Vào https://myaccount.google.com/security
#   3. Bật "Xác minh 2 bước" (2-Step Verification)
#   4. Vào "Mật khẩu ứng dụng" (App passwords)
#   5. Chọn Ứng dụng: Thư, Thiết bị: Khác (đặt tên: approval-system)
#   6. Copy password 16 ký tự được tạo (không có dấu cách)
#
# Ví dụ SMTP_PASS: abcdfghiyjklmnop

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=congphu.0303@gmail.com
SMTP_PASS=mkdpckeutidoecga

