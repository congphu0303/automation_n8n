# ═══════════════════════════════════════════════════════════════════
# MONGODB ATLAS CONNECTION
# ═══════════════════════════════════════════════════════════════════
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.xxxxx.mongodb.net/approval_system


# ═══════════════════════════════════════════════════════════════════
# JWT SECRET KEY
# ═══════════════════════════════════════════════════════════════════
JWT_SECRET=<paste_32_char_random_key_here>


# ═══════════════════════════════════════════════════════════════════
# SMTP EMAIL CONFIG
# ═══════════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your-gmail@gmail.com>
SMTP_PASS=<16-char-app-password>


# ═══════════════════════════════════════════════════════════════════
# APPLICATION CONFIG
# ═══════════════════════════════════════════════════════════════════
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000


# ═══════════════════════════════════════════════════════════════════
# HR EMAIL - Người duyệt cấp 2
# ═══════════════════════════════════════════════════════════════════
HR_EMAIL=<hr@yourcompany.com>
Manager_EMAIL=<manager@yourcompany.com>

# ═══════════════════════════════════════════════════════════════════
# N8N WEBHOOK URLs (tuỳ chọn)
# ═══════════════════════════════════════════════════════════════════
# Lấy từ n8n workflow → Copy Webhook URL
N8N_LEAVE_WEBHOOK=https://n8n.yourdomain.com/webhook/leave-request
N8N_APPROVAL_WEBHOOK=https://n8n.yourdomain.com/webhook/approval-decision
