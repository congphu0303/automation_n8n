    {
      "parameters": {
        "resource": "message",
        "htmlMessage": "=<div style=\"font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden;\">\n    <div style=\"background-color: #2563eb; color: #ffffff; padding: 20px; text-align: center;\">\n        <h2 style=\"margin: 0; font-size: 20px; text-transform: uppercase; letter-spacing: 1px;\">Thông Báo Phê Duyệt Nghỉ Phép</h2>\n    </div>\n\n    <div style=\"padding: 30px;\">\n        <p style=\"margin-top: 0;\">Kính gửi Quản lý,</p>\n        <p>Hệ thống ghi nhận một yêu cầu nghỉ phép mới cần được xem xét. Dưới đây là thông tin chi tiết từ nhân viên:</p>\n\n        <table style=\"width: 100%; border-collapse: collapse; margin: 20px 0; background-color: #f9fafb; border-radius: 8px;\">\n            <tr>\n                <td style=\"padding: 12px 15px; font-weight: bold; width: 140px; color: #6b7280; border-bottom: 1px solid #edf2f7;\">Nhân viên:</td>\n                <td style=\"padding: 12px 15px; border-bottom: 1px solid #edf2f7;\"><strong>{{ $json.employeeName }}</strong></td>\n            </tr>\n            <tr>\n                <td style=\"padding: 12px 15px; font-weight: bold; color: #6b7280; border-bottom: 1px solid #edf2f7;\">Phòng ban:</td>\n                <td style=\"padding: 12px 15px; border-bottom: 1px solid #edf2f7;\">{{ $json.department }}</td>\n            </tr>\n            <tr>\n                <td style=\"padding: 12px 15px; font-weight: bold; color: #6b7280; border-bottom: 1px solid #edf2f7;\">Thời gian nghỉ:</td>\n                <td style=\"padding: 12px 15px; border-bottom: 1px solid #edf2f7;\">{{ $json.leaveDate }}</td>\n            </tr>\n            <tr>\n                <td style=\"padding: 12px 15px; font-weight: bold; color: #6b7280; border-bottom: 1px solid #edf2f7;\">Tổng số ngày:</td>\n                <td style=\"padding: 12px 15px; border-bottom: 1px solid #edf2f7;\">{{ $json.leaveDays }} ngày</td>\n            </tr>\n            <tr>\n                <td style=\"padding: 12px 15px; font-weight: bold; color: #6b7280;\">Lý do:</td>\n                <td style=\"padding: 12px 15px;\">{{ $json.reason }}</td>\n            </tr>\n        </table>\n\n        <p style=\"margin-bottom: 30px;\">Vui lòng nhấp vào nút bên dưới để tiến hành phê duyệt hoặc từ chối yêu cầu này trên hệ thống quản trị.</p>\n\n        <div style=\"text-align: center;\">\n            <a href=\"{{ $json.managerApprovalLink }}\" \n               style=\"background-color: #2563eb; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 8px; font-weight: bold; display: inline-block; box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);\">\n               Xem xét & Phản hồi\n            </a>\n        </div>\n    </div>\n\n    <div style=\"background-color: #f3f4f6; color: #9ca3af; padding: 15px; text-align: center; font-size: 12px;\">\n        <p style=\"margin: 0;\">Đây là email tự động từ Hệ thống Quản trị Nhân sự n8n.</p>\n        <p style=\"margin: 5px 0 0 0;\">Vui lòng không phản hồi lại email này.</p>\n    </div>\n</div>",
        "subject": "=Yêu cầu nghỉ phép từ {{ $json.body.employeeName }}",
        "includeHtml": "={{ true }}",
