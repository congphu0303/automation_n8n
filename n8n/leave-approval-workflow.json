    {
      "parameters": {
        "functionCode": "return items.map(item => {\n  // Backend HR gọi webhook với payload: { action, employeeEmail, employeeName, leaveDate, leaveDays, reason }\n  let bodyData = item.json.body || {};\n  let rootData  = item.json;\n  \n  // Loại bỏ body khỏi root để merge không bị trùng\n  let cleanRoot = { ...rootData };\n  delete cleanRoot.body;\n  delete cleanRoot.headers;\n  delete cleanRoot.query;\n  delete cleanRoot.params;\n\n  // Merge: root < body  (body có priority cao hơn)\n  let merged = { ...cleanRoot, ...bodyData };\n\n  return {\n    json: {\n      action:        merged.action        || \"\",\n      employeeEmail: merged.employeeEmail || \"\",\n      employeeName:  merged.employeeName  || \"Unknown\",\n      leaveDate:     merged.leaveDate     || \"\",\n      leaveDays:     merged.leaveDays     || 0,\n      reason:        merged.reason        || \"\",\n      token:         merged.token          || \"\",\n    }\n  };\n});"
      },
