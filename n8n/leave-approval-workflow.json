    {
      "parameters": {
        "functionCode": "return items.map(item => {\n  // Frontend gửi dữ liệu dạng: { body: { hrApprovalLink, employeeEmail, ... } }\n  // Hoặc dạng flat:   { hrApprovalLink, employeeEmail, ... }\n  // Hoặc dạng query:  { query: { hrApprovalLink, ... } }\n\n  let bodyData = item.json.body || {};\n  let queryData = item.json.query || {};\n  let rootData  = item.json;\n\n  // Loại bỏ body/query khỏi root để spread không bị trùng\n  let cleanRoot = { ...rootData };\n  delete cleanRoot.body;\n  delete cleanRoot.query;\n  delete cleanRoot.headers;\n  delete cleanRoot.params;\n\n  // Merge: root < query < body  (body có priority cao nhất)\n  let merged = {\n    ...cleanRoot,\n    ...queryData,\n    ...bodyData\n  };\n\n  return {\n    json: {\n      token:         merged.token          || \"\",\n      action:        merged.action         || \"\",\n      employeeName:  merged.employeeName  || \"Unknown\",\n      hrApprovalLink:merged.hrApprovalLink || \"\",\n      employeeEmail: merged.employeeEmail || \"\",\n      leaveDate:     merged.leaveDate     || \"\",\n      leaveDays:     merged.leaveDays     || 0,\n      reason:        merged.reason        || \"\",\n      raw_data:      merged\n    }\n  };\n});"
      },
      "id": "16ee9871-3a91-4c8d-b25c-2de1b966adce",
      "name": "Parse Decision",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1008,
        2720
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.action }}",
        "rules": {
          "rules": [
            {
              "value2": "=approve"
            },
            {
              "value2": "=reject",
              "output": 1
            },
            {
              "value2": "=waiting_hr",
              "output": 2
            }
          ]
        }
      },
      "id": "49743a65-8f22-4656-8cd0-d46416ba4db6",
