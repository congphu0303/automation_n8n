      "id": "cd628348-55f9-4750-82d2-ff8241fe562a",
      "name": "Manager Decision Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        6096,
        6528
      ],
      "webhookId": "manager-decision"
