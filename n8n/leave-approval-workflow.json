        "jsCode": "const body = $input.all()[0].json.body || $input.all()[0].json;\n\nconst actual = new Date(body.actualReturnDate);\nconst planned = new Date(body.plannedEndDate);\n\n// Tính khoảng thời gian chênh lệch\nconst diffTime = planned.getTime() - actual.getTime();\nlet refundDays = Math.ceil(diffTime / (1000 * 3600 * 24));\n\nreturn {\n  json: {\n    ...body,\n    refundDays: refundDays\n  }\n};"
