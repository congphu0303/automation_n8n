    {
      "parameters": {
        "functionCode": "return items.map(item => {\n  const dept = item.json.department;\n  const managerEmails = item.json.managerEmails || {};\n  const hrEmail = item.json.hrEmail || \"phupc.23ite@vku.udn.vn\";\n\n  // Map department → manager email\n  const emailMap = {\n    IT: managerEmails.IT,\n    Marketing: managerEmails.Marketing,\n    Finance: managerEmails.Finance,\n    Sales: managerEmails.Sales\n  };\n\n  // Nếu department có trong 4 phòng ban → dùng manager email của phòng đó\n  // Nếu không (HR, Operations, etc.) → dùng hrEmail\n  item.json.manager_email = emailMap[dept] || hrEmail;\n\n  return item;\n});"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
