    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst bookedSlots = { 'ROOM-A': [], 'ROOM-B': ['09:00-10:00'], 'ROOM-C': [], 'ROOM-D': ['09:00-17:00'] };\nconst slots = bookedSlots[data.room_id] || [];\nlet conflict = false;\nfor (const slot of slots) { const [s,e] = slot.split('-'); if (data.start_time < e && data.end_time > s) { conflict=true; break; } }\nreturn [{ json: { ...data, room_available: !conflict } }];"
      },
