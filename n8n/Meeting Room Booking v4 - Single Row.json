      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst required = ['requester_name','requester_email','department','room_id','meeting_date','start_time','end_time','purpose'];\nconst missing = required.filter(f => !body[f]);\nif (missing.length > 0) return [{ json: { valid: false, errors: missing } }];\nconst bookingId = 'MTG-' + Date.now().toString(36).toUpperCase();\nreturn [{ json: { valid: true, booking_id: bookingId, requester_name: body.requester_name, requester_email: body.requester_email, department: body.department, room_id: body.room_id, room_name: body.room_name || body.room_id, meeting_date: body.meeting_date, start_time: body.start_time, end_time: body.end_time, attendees: body.attendees || 1, purpose: body.purpose, notes: body.notes || '', status: 'pending_approval', created_at: new Date().toISOString(), manager_email: body.manager_email || 'manager@company.com' } }];"
      },
